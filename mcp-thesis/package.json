{
  "name": "mcp-thesis",
  "version": "0.1.0",
  "description": "A Model Context Protocol server",
  "private": true,
  "type": "module",
  "bin": {
    "mcp-thesis": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "lodash": "^4.17.21",
    "zod": "3"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  }
}
