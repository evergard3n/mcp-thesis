{
  "name": "mcp-thesis",
  "version": "0.1.0",
  "description": "A Model Context Protocol server",
  "private": true,
  "type": "module",
  "bin": {
    "mcp-thesis": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepack": "npm run build",
    "watch": "tsc --watch",
    "dev": "npx -y tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lodash": "^4.17.21",
    "zod": "3",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  }
}
