# Server Configuration
PORT=3006

# OpenRouter API Key (required for using Gemini through OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Note: Gemini API key is now passed via HTTP header (x-gemini-api-key)
# instead of environment variables for better security and per-session isolation
# The server uses OpenRouter with Gemini 2.0 Flash model for all LLM operations